# Wagtail / Django media (images, documents) on Cloudflare R2
USE_R2_MEDIA=true
R2_BUCKET_NAME=your-bucket
R2_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL (R2 custom domain or r2.dev public bucket URL)
R2_PUBLIC_BASE_URL=https://media.example.com
# R2_REGION=auto

B2_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002
B2_BUCKET=your-b2-bucket-name
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
# Public base URL — pick ONE style (do not mix S3 host with /file):
#   Friendly (from B2 bucket “Friendly URL”): https://f005.backblazeb2.com/file
#   S3-style (same region as B2_S3_ENDPOINT):  https://s3.us-east-005.backblazeb2.com
# Wrong: https://s3.us-east-005.backblazeb2.com/file  ← breaks image/video URLs
B2_PUBLIC_BASE_URL=https://s3.us-east-005.backblazeb2.com

# Bucket access:
#   Private bucket (default): B2_PLAYBACK_USE_PRESIGNED=true
#   Public bucket (allPublic in B2): B2_PLAYBACK_USE_PRESIGNED=false
# B2_PLAYBACK_USE_PRESIGNED=false
# B2_PLAYBACK_PRESIGNED_EXPIRES=86400

# Optional: ffmpeg binary path (defaults to "ffmpeg")
# FFMPEG_BIN=/usr/bin/ffmpeg

# Global Solutions videos: omit or false = progressive MP4 after upload (no CLI).
# GLOBAL_SOLUTIONS_TRANSCODE_HLS=false

# Max READY videos per category on /global-solutions/ (each category scrolls horizontally).
# GLOBAL_SOLUTIONS_PUBLIC_VIDEO_CAP=72

